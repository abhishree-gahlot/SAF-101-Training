5. JOIN QUERY
SELECT 
    c.customer_id,
    c.name,
    c.phone,
    a.city,
    a.state,
    a.pincode,
    p.plan_name,
    p.price,
    p.speed
FROM Customer c
INNER JOIN Address a ON c.customer_id = a.customer_id
INNER JOIN Plan p ON c.customer_id = p.customer_id;

6. VIEW TABLE
CREATE VIEW CustomerFullView AS
SELECT 
    c.customer_id,
    c.name,
    c.phone,
    a.city,
    a.state,
    a.pincode,
    p.plan_name,
    p.price,
    p.speed
FROM Customer c
INNER JOIN Address a ON c.customer_id = a.customer_id
INNER JOIN Plan p ON c.customer_id = p.customer_id;

7. USE VIEW
SELECT * FROM CustomerFullView;

