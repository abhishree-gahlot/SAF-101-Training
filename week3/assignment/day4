1. CUSTOMER TABLE
CREATE TABLE Customer (
    customer_id INT PRIMARY KEY,
    name VARCHAR(50),
    phone VARCHAR(15)
);


2. ADDRESS TABLE
CREATE TABLE Address (
    address_id INT PRIMARY KEY,
    customer_id INT,
    city VARCHAR(50),
    state VARCHAR(50),
    pincode VARCHAR(10),
    FOREIGN KEY (customer_id) REFERENCES Customer(customer_id)
);

3. PLAN TABLE
CREATE TABLE Plan (
    plan_id INT PRIMARY KEY,
    customer_id INT,
    plan_name VARCHAR(50),
    price INT,
    speed VARCHAR(20),
    FOREIGN KEY (customer_id) REFERENCES Customer(customer_id)
);

